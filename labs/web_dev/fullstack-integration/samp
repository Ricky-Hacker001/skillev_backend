async function syncWithBackend() {
    // 1. Fetch the status from /api/status (This part is usually correct)
    const statusRes = await fetch('/api/status');
    const statusData = await statusRes.json();
    console.log('Status:', statusData.status);

    // 2. Fetch the secure data (Fixing the Headers and Body)
    const dataRes = await fetch('/api/data', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer SK-9921-X' // Token added here
        },
        body: JSON.stringify({ request_code: 'REQ_DATA' }) // Request code added here
    });

    const finalData = await dataRes.json();
    
    // If successful, this returns the SKILLEV flag
    return finalData.secret || finalData.message;
}

syncWithBackend();